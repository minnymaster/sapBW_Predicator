# =============================================================================
# Tests API — environment variables
# Скопируйте в .env и заполните реальными значениями
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL — certification_db (Tests API)
# -----------------------------------------------------------------------------
CERTIFICATION_DATABASE_URL="postgresql://certification_user:certification_pass@localhost:5434/certification_db?schema=public"

# -----------------------------------------------------------------------------
# JWT (RS256) — публичный ключ от Auth-сервиса (PEM, \n вместо переносов строк)
# -----------------------------------------------------------------------------
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA...\n-----END PUBLIC KEY-----"

# -----------------------------------------------------------------------------
# Сервис
# -----------------------------------------------------------------------------
PORT=3001
NODE_ENV=development

# -----------------------------------------------------------------------------
# LLM — провайдер
# LLM_PROVIDER: groq | lmstudio
# -----------------------------------------------------------------------------
LLM_PROVIDER=groq

# Groq Cloud (https://console.groq.com/keys)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LM Studio (локально, оставьте пустым при использовании Groq)
# LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Общие параметры LLM (используются LlmService)
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.1-70b-versatile
LLM_TIMEOUT_MS=30000