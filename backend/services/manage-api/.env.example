COMPANY_DATABASE_URL=postgresql://manage_user:manage_pass@localhost:5434/company_db
PORT=3002

# Путь к каталогу с RSA-ключами (JWT RS256)
# Если ключи отсутствуют — KeysService сгенерирует их автоматически при старте
JWT_KEYS_DIR=./keys

# TTL токена (должен совпадать с JWT_TTL_SECONDS = 900)
JWT_EXPIRES_IN=15m